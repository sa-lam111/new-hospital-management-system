# ===================================
# ENVIRONMENT CONFIGURATION
# ===================================
# For PRODUCTION: Change values and deploy
# For DEVELOPMENT: Use localhost values

# ===== SERVER =====
PORT=5000
NODE_ENV=production  # Set to 'production' for deployment

# ===== DATABASE (MongoDB) =====
# LOCAL DEVELOPMENT:
# MONGODB_URI=mongodb://localhost:27017/hospital-db
#
# PRODUCTION (MongoDB Atlas):
# 1. Go to https://cloud.mongodb.com
# 2. Create cluster and database user
# 3. Copy connection string below
MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/hospital-db?retryWrites=true&w=majority

# ===== JWT SECURITY =====
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# Must be at least 32 characters for production
JWT_SECRET=your_super_secret_32_character_string_minimum
JWT_EXPIRE=7d

# ===== EMAIL (Gmail with App Password) =====
# 1. Go to https://myaccount.google.com/security
# 2. Enable 2-factor authentication
# 3. Go to https://myaccount.google.com/apppasswords
# 4. Generate app password (16 characters)
# 5. Paste it as EMAIL_PASS below
EMAIL_SERVICE=gmail
EMAIL_USER=your_email@gmail.com
EMAIL_PASS=your_16_char_app_password
EMAIL_FROM=noreply@yourhospital.com

# ===== FRONTEND =====
# DEVELOPMENT:
# FRONTEND_URL=http://localhost:5174
#
# PRODUCTION:
# FRONTEND_URL=https://yourdomain.com,https://www.yourdomain.com
FRONTEND_URL=https://yourdomain.com

# ===== RATE LIMITING =====
RATE_LIMIT_WINDOW_MS=900000  # 15 minutes
RATE_LIMIT_MAX_REQUESTS=100  # Per IP per window

# ===== LOGGING =====
LOG_LEVEL=info  # Set to 'error' in production
