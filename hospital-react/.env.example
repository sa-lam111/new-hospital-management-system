# ===================================
# FRONTEND ENVIRONMENT VARIABLES
# ===================================
# Copy this file to .env.local and fill in your values

# ===== API CONFIGURATION =====
# DEVELOPMENT: http://localhost:5000/api
# PRODUCTION: https://your-railway-url.railway.app/api
# Replace 'your-railway-url' with your actual Railway project URL
VITE_API_BASE_URL=https://your-railway-url.railway.app/api

# ===== APP CONFIGURATION =====
VITE_APP_NAME=Hospital Management System
VITE_APP_VERSION=1.0.0

# ===== FEATURE FLAGS =====
VITE_ENABLE_ANALYTICS=false
VITE_ENABLE_NOTIFICATIONS=true

# ===== API TIMEOUTS =====
VITE_API_TIMEOUT=30000

# ===================================
# DEPLOYMENT INSTRUCTIONS
# ===================================
# 1. After deploying backend to Railway:
#    - Get your Railway project URL (e.g., project-name-production.railway.app)
#    - Replace 'your-railway-url' with your actual URL
#    
# 2. Deploy to Vercel:
#    - Connect GitHub repo to Vercel
#    - Set this environment variable in Vercel project settings
#    - Redeploy if needed
#    
# 3. Never commit .env.local to git
#    - It's already in .gitignore
